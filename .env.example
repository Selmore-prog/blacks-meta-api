# --- Servidor ---
PORT=8080

# --- Base de datos (Supabase Postgres, preferentemente pooler puerto 6543) ---
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# --- Tiendanube ---
TIENDANUBE_STORE_ID=000000
TIENDANUBE_ACCESS_TOKEN=
TIENDANUBE_USER_AGENT=BlacksContentEngine (tu-email@blacksindumentaria.com.ar)
TIENDANUBE_AUTH_HEADER_STYLE=authorization

# --- IA de copy/imagen ---
# Gemini (Google AI Studio): https://aistudio.google.com/apikey
# El COPY con gemini-2.5-flash es GRATIS. Las keys nuevas (AQ.) funcionan igual.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# AI_PROVIDER: 'gemini' (usa Gemini y cae a Groq si falla) | 'groq'
AI_PROVIDER=gemini
# OJO: la generación de IMÁGENES con IA en Gemini es PAGA (da 429 en el tier gratis).
# Dejalo en false para NO tener costo: las piezas se arman con la plantilla (gratis y prolija).
AI_IMAGES=false

# Groq (fallback de copy, gratis): https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Supabase Storage ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=blacks-assets

# --- Seguridad para endpoints programados (Cron Jobs) ---
CRON_SECRET=mi-clave-secreta-para-cron

# --- Meta / Instagram / Facebook Graph API ---
META_PAGE_ACCESS_TOKEN=
IG_USER_ID=
META_PAGE_ID=
# Pilares que se auto-publican (el resto queda para revisar/publicar a mano)
AUTO_PUBLISH_PILLARS=promo,producto

# --- Meta Ads (lectura de pauta: gasto, ROAS, CAC en el panel de Métricas) ---
# Token con scope ads_read. Si queda vacío se intenta con META_PAGE_ACCESS_TOKEN.
# Los tokens de Graph Explorer duran horas: extenderlo a ~60 días con el botón
# "Extend Access Token" en https://developers.facebook.com/tools/debug/accesstoken
META_ADS_ACCESS_TOKEN=
# ID de la cuenta publicitaria (con prefijo act_). Sin esto, la sección no aparece.
META_AD_ACCOUNT_ID=act_1234567890
# Catálogo de Meta que usan los anuncios dinámicos: el motor corrige su disponibilidad
# (in stock / out of stock) con el stock real de Tiendanube, a mano y en el cron diario.
# Requiere que el token tenga catalog_management.
META_CATALOG_ID=

# --- URL pública donde queda este servicio (Render) ---
PUBLIC_BASE_URL=https://tu-servicio.onrender.com

# --- Telegram (avisos: piezas nuevas, publicaciones, informe semanal) ---
# Crear bot con @BotFather; el chat id sale de https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Imágenes con IA (OPCIONAL) ---
# OJO: la suscripción Google AI Pro (US$20/mes) NO incluye la API de imágenes.
# Para activarlas hay que habilitar facturación pay-as-you-go del proyecto en
# AI Studio (se cobra por imagen generada). El copy de TEXTO con gemini-2.5-flash sí es gratis.
# Modelos compatibles con este código (usan generateContent con imagen inline):
#   gemini-3.1-flash-image (barato) | gemini-3-pro-image (máxima calidad)
#   (los "imagen-4.0-*" NO sirven acá: usan otra API distinta)
# AI_IMAGES=true
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
